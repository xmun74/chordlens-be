SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
ALLOWED_ORIGIN=https://your-fe-domain.com

# yt-dlp / Webshare proxy
# Put the Webshare country/sticky-session proxy URL here as provided by Webshare.
YTDLP_PROXY_URL=http://USERNAME:PASSWORD@HOST:PORT
YTDLP_PROXY_COUNTRY=US
YTDLP_USE_COOKIES=false
YTDLP_RETRY_COUNT=1
YTDLP_BACKOFF_SECONDS=5
